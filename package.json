{
  "name": "knowledge-base-qa",
  "version": "1.0.0",
  "description": "基于知识库的AI问答系统",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "start": "node render-server.js",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "install:all": "npm install && cd client && npm install",
    "render-start": "node render-server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "gray-matter": "^4.0.3",
    "lunisolar": "^2.6.0",
    "node-fetch": "^2.7.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
