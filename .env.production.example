# ============================================
# 生产环境配置
# ============================================

# 通义千问 (阿里云) 大模型配置
NEXT_PUBLIC_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
NEXT_PUBLIC_LLM_API_KEY=你的通义千问API密钥
NEXT_PUBLIC_LLM_MODEL=qwen-turbo  # 可选：qwen-turbo, qwen-plus, qwen-max

# 服务器配置
PORT=3001
NODE_ENV=production

# 安全配置（用于生产环境）
# 生成随机字符串：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=生成一个随机的32位十六进制字符串
CORS_ORIGIN=https://你的域名.com  # 或 http://localhost:5173 用于本地测试

# 日志配置
LOG_LEVEL=info
LOG_DIR=./logs

# 性能配置
MAX_REQUEST_SIZE=10mb
REQUEST_TIMEOUT=30000

# 数据库配置（如果需要）
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=knowledge_base
# DB_USER=postgres
# DB_PASSWORD=your_password

# 邮件配置（用于错误通知）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# ADMIN_EMAIL=admin@example.com

# 监控配置
ENABLE_METRICS=true
METRICS_PORT=9090

# 备份配置
BACKUP_DIR=/var/backups/knowledge-base
BACKUP_SCHEDULE=0 2 * * *  # 每天凌晨2点备份