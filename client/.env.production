# Cloudflare Pages生产环境配置
# 需要配置在Cloudflare Pages的环境变量中

# Render后端API地址
VITE_API_URL=https://knowledge-base-qa.onrender.com

# 通义千问配置（这些变量会通过后端API调用，不在前端暴露）
NEXT_PUBLIC_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
NEXT_PUBLIC_LLM_MODEL=qwen-turbo

# 应用名称
VITE_APP_NAME=知识库AI问答系统
VITE_APP_DESCRIPTION=基于通义千问大模型的智能问答系统