# ============================================
# 大模型配置示例文件
# 复制此文件为 .env 并修改相应配置
# ============================================

# ======================
# OpenAI GPT系列 配置
# ======================
# NEXT_PUBLIC_LLM_BASE_URL=https://api.openai.com/v1
# NEXT_PUBLIC_LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_LLM_MODEL=gpt-3.5-turbo
# # 可选模型: gpt-3.5-turbo, gpt-4, gpt-4-turbo, gpt-4o

# ======================
# Claude API (Anthropic) 配置
# ======================
# NEXT_PUBLIC_LLM_BASE_URL=https://api.anthropic.com
# NEXT_PUBLIC_LLM_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_LLM_MODEL=claude-3-sonnet-20240229
# # 可选模型: claude-3-haiku, claude-3-sonnet, claude-3-opus

# ======================
# Azure OpenAI 配置
# ======================
# NEXT_PUBLIC_LLM_BASE_URL=https://YOUR_RESOURCE_NAME.openai.azure.com/openai/deployments/YOUR_DEPLOYMENT_NAME
# NEXT_PUBLIC_LLM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_LLM_MODEL=gpt-35-turbo
# # 注意: Azure OpenAI的Base URL格式不同

# ======================
# 腾讯云 DeepSeek 配置
# ======================
# TENCENT_SECRET_ID=your_tencent_secret_id_here
# TENCENT_SECRET_KEY=your_tencent_secret_key_here
# TENCENT_API_ENDPOINT=https://lkeap.tencentcloudapp.com
# # 模型名称在代码中固定为 'deepseek-r1'

# ======================
# 通义千问 (阿里云) 配置
# ======================
# NEXT_PUBLIC_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# NEXT_PUBLIC_LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_LLM_MODEL=qwen-turbo
# # 可选模型: qwen-turbo, qwen-plus, qwen-max

# ======================
# 文心一言 (百度) 配置
# ======================
# NEXT_PUBLIC_LLM_BASE_URL=https://aip.baidubce.com/rpc/2.0/ai_custom/v1/wenxinworkshop/chat/completions
# NEXT_PUBLIC_LLM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_LLM_MODEL=ERNIE-Bot-turbo
# # 可选模型: ERNIE-Bot, ERNIE-Bot-turbo, ERNIE-Bot-4

# ======================
# 智谱GLM (清华) 配置
# ======================
# NEXT_PUBLIC_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# NEXT_PUBLIC_LLM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_LLM_MODEL=glm-4
# # 可选模型: glm-3-turbo, glm-4

# ======================
# 月之暗面 (Kimi) 配置
# ======================
# NEXT_PUBLIC_LLM_BASE_URL=https://api.moonshot.cn/v1
# NEXT_PUBLIC_LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_LLM_MODEL=moonshot-v1-8k
# # 可选模型: moonshot-v1-8k, moonshot-v1-32k, moonshot-v1-128k

# ======================
# DeepSeek (深度求索) 配置
# ======================
# NEXT_PUBLIC_LLM_BASE_URL=https://api.deepseek.com
# NEXT_PUBLIC_LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_LLM_MODEL=deepseek-chat
# # 可选模型: deepseek-chat, deepseek-reasoner

# ======================
# Ollama (本地模型) 配置
# ======================
# NEXT_PUBLIC_LLM_BASE_URL=http://localhost:11434/v1
# NEXT_PUBLIC_LLM_API_KEY=ollama  # Ollama不需要API Key，但需要填写一个占位符
# NEXT_PUBLIC_LLM_MODEL=llama3
# # 可选模型: llama3, mistral, codellama, gemma等

# ======================
# 向量模型配置 (固定)
# ======================
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# ======================
# 服务器配置
# ======================
PORT=3001